generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum RiskLevel {
  LOW
  MEDIUM
  HIGH
}

enum EscalationStatus {
  PENDING
  IN_REVIEW
  UNDER_REVIEW
  RESOLVED
  REJECTED
}

enum ReportType {
  SAR
  STR
}

model Tenant {
  id           String   @id @default(uuid())
  name         String
  slug         String   @unique
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  users         User[]
  accounts      Account[]
  transactions  Transaction[]
  decisionRules DecisionRule[]
}

model User {
  id          String   @id @default(uuid())
  email       String   @unique
  password    String
  role        String
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id])

  mfaEnabled  Boolean  @default(false)
  mfaSecret   String?

  escalations Escalation[]
  auditLogs   AuditLog[]
  createdAt   DateTime @default(now())
}

model Account {
  id            String   @id @default(uuid())
  accountNumber String
  tenantId      String
  tenant        Tenant   @relation(fields: [tenantId], references: [id])

  status        String   @default("ACTIVE")
  metadata      Json?

  transactions Transaction[]
}

model Transaction {
  id            String   @id @default(uuid())
  transactionRef String
  amount        Float
  currency      String
  senderCountry String?
  receiverCountry String?
  identifier    String?
  status        String
  riskScore     Int      @default(0)
  senderName    String?
  anomalyFlag   Boolean  @default(false)
  graphFlag     Boolean  @default(false)

  tenantId      String
  tenant        Tenant   @relation(fields: [tenantId], references: [id])

  accountId     String
  account       Account  @relation(fields: [accountId], references: [id])

  riskResult    RiskResult?
  escalation    Escalation?

  createdAt     DateTime @default(now())
}

model RiskResult {
  id              String   @id @default(uuid())
  transactionId   String   @unique
  transaction     Transaction @relation(fields: [transactionId], references: [id])

  anomalyScore    Float
  supervisedProb  Float
  graphFlag       Boolean
  finalRiskScore  Int
  riskLevel       RiskLevel

  explanation     Json
  modelVersionId  String
  modelVersion    ModelVersion @relation(fields: [modelVersionId], references: [id])

  createdAt       DateTime @default(now())
}

model Escalation {
  id            String   @id @default(uuid())
  transactionId String   @unique
  transaction   Transaction @relation(fields: [transactionId], references: [id])

  tenantId      String
  assignedToId  String?
  assignedTo    User? @relation(fields: [assignedToId], references: [id])

  status        EscalationStatus @default(PENDING)
  priority      String           @default("MEDIUM")
  resolution    String?
  notes         String?
  resolvedBy    String?
  resolvedAt    DateTime?

  createdAt     DateTime @default(now())
}

model ComplianceReport {
  id            String   @id @default(uuid())
  type          ReportType
  status        String
  tenantId      String
  transactionIds Json
  content       Json
  generatedBy   String
  filingDate    DateTime?
  createdAt     DateTime @default(now())
}

model DecisionRule {
  id        String   @id @default(uuid())
  tenantId  String
  tenant    Tenant @relation(fields: [tenantId], references: [id])

  blockThreshold   Int
  flagThreshold    Int
  autoEscalateAbove Int?

  createdAt DateTime @default(now())
}

model ModelVersion {
  id          String   @id @default(uuid())
  name        String
  metrics     Json
  createdAt   DateTime @default(now())

  riskResults RiskResult[]
}

model AuditLog {
  id        String   @id @default(uuid())
  action    String
  entity    String
  entityId  String?
  details   Json
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  ipAddress String?
  metadata  Json?
  createdAt DateTime @default(now())
}
