rules_version = '2';

/**
 * 🛡️ PATHGUARD (PROJECT AEGIS): OMEGA PROTOCOL V2.0
 * FIRESTORE.RULES - Zero-Trust Global Security Configuration
 * 
 * ☢️ NUCLEAR WARNING:
 * Rules are the only barrier between users and total data exposure.
 * Misconfiguration here = Legal Liability + Fines + Ruin.
 * Test these rules using the Firebase Emulator before every deployment.
 */

service cloud.firestore {
  match /databases/{database}/documents {
    
    // 🌍 HELPER: Checks if current time is within business hours (UTC 09:00 - 17:00)
    function isBusinessHours() {
      return request.time.hour() >= 9 && request.time.hour() < 17;
    }

    // 🛡️ HELPER: Checks if the user has the 'admin' claim
    function isAdmin() {
      return request.auth.token.admin == true;
    }

    // 📍 HELPER: Checks geo-location (Sovereignty Verification)
    function isAuthorizedGeo() {
      // ☢️ WARNING: This relies on Custom Claims injected by Cloud Functions via ZTNA
      return request.auth.token.geo_verified == true;
    }

    // 👤 USERS: Read/Write own profile only
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // 💸 TRANSACTIONS: Financial Immutability (INSERT ONLY)
    match /transactions/{transactionId} {
      allow create: if request.auth != null && 
                      request.resource.data.user_id == request.auth.uid &&
                      isAuthorizedGeo();
      
      // ☢️ NUCLEAR RULE: No updates or deletes allowed for financial records.
      allow update, delete: if false;
      
      allow read: if request.auth != null && 
                    (resource.data.user_id == request.auth.uid || isAdmin());
    }

    // 🖋️ AUDIT LOGS: Maximum Persistence (INSERT ONLY)
    match /audit_logs/{logId} {
      allow create: if request.auth != null;
      allow read: if isAdmin();
      
      // ☢️ NUCLEAR RULE: Audit logs CANNOT be modified or deleted by anyone, including admins.
      allow update, delete: if false;
    }

    // 🚫 DEFAULT DENY: Any path not explicitly allowed is BLOCKED.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
